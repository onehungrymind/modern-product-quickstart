{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "es2022"
    ],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "strictNullChecks": true,
    "target": "es2022",
    "paths": {
      "@tracer/common-models": [
        "./libs/common-models/src/index.ts"
      ],
      "@tracer/design-tokens": [
        "./libs/design-tokens/src/index.ts"
      ],
      "@tracer/material": [
        "./libs/material/src/index.ts"
      ],
      "@tracer/core-data": [
        "./libs/core-data/src/index.ts"
      ],
      "@tracer/core-state": [
        "./libs/core-state/src/index.ts"
      ]
    },
    "sourceMap": true
  }
}

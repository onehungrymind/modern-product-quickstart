  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "workspaces": [
    "libs/*",
    "apps/*"
  ],
  "scripts": {
    "start": "nx run-many -t serve -p web,api --parallel=2",
    "serve:api": "nx serve api",
    "serve:web": "nx serve web",
    "build": "nx run-many -t build -p web,api",
    "build:prod": "nx run-many -t build -p web,api --configuration=production",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint --fix",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "verify": "nx run-many -t typecheck lint test build",
    "e2e": "nx e2e web-e2e",
    "e2e:smoke": "nx e2e web-e2e -- --project=smoke",
    "e2e:bdd": "nx e2e web-e2e -- --project=bdd",
    "e2e:bdd:gen": "nx run web-e2e:bdd-gen",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "graph": "nx graph",
    "clean": "nx reset",
    "module:begin": "node scripts/module.mjs begin",
    "module:compare": "node scripts/module.mjs compare",
    "module:reset": "node scripts/module.mjs reset",
    "module:status": "node scripts/module.mjs status",
    "rebuild-tags": "node scripts/rebuild-tags.mjs"
  },

# Tracer API — dev defaults (committed intentionally; seed-grade)
# These are the same defaults hard-coded in the app. Override for prod.

NODE_ENV=development
PORT=3000

DATABASE_URL=postgres://tracer:tracer@localhost:5433/tracer
DB_LOGGING=false
DATABASE_SSL=false

JWT_SECRET=dev-not-secret-change-me

CORS_ORIGINS=http://localhost:4200

# URL_PREVIEW=stub|real (default: real; auto-stub when NODE_ENV=test)
URL_PREVIEW=real
